<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox off: we need CGEvent injection (Accessibility), full screen
	     capture, and unrestricted Bonjour browsing/advertising. None of those
	     play well with the App Store sandbox. The MAS build will have a
	     reduced feature set in a separate entitlements file once it ships. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
